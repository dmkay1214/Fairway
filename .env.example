# ============================================================
# FAIRWAY MARKETPLACE — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ─── Supabase ─────────────────────────────────────────────────
# Get these from: https://app.supabase.com
# → Your project → Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe (payments) ────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use TEST keys for development, LIVE keys for production

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Server-side only (never expose in frontend):
# STRIPE_SECRET_KEY=sk_test_your-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# ─── App config ───────────────────────────────────────────────
VITE_APP_NAME=Fairway
VITE_APP_URL=http://localhost:5173

# Platform fee percentage (e.g. 3 = 3%)
VITE_PLATFORM_FEE_PCT=3
